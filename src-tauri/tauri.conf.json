{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FortiVPN Tray",
  "version": "0.1.0",
  "identifier": "com.ktutnik.fortivpn-tray",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/fortivpn-helper"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
